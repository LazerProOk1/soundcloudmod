{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SoundCloud Desktop",
  "version": "1.2.0",
  "identifier": "com.soundcloud.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SoundCloud Desktop",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 470,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "publisher": "SoundCloud Desktop",
    "copyright": "© 2026 SoundCloud Desktop",
    "windows": {
      "nsis": {
        "languages": ["Russian"],
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "compression": "lzma",
        "headerImage": "nsis/header.bmp",
        "sidebarImage": "nsis/sidebar.bmp",
        "installerIcon": "icons/icon.ico"
      },
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
